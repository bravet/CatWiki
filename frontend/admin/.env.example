# ============================================
# Admin 前端环境变量配置
# 复制此文件为 .env.local (本地开发) 或 .env (Docker)
# ============================================

# ===== API 配置 =====
# 后端 API 地址（浏览器端访问）
# 本地开发：http://localhost:3000
# Docker 开发：http://localhost:3000
# 生产环境：https://api.catwiki.ai
NEXT_PUBLIC_API_URL=http://localhost:3000

# Client 前端地址（AI 问答跳转）
# 本地开发：http://localhost:8002
# Docker 开发：http://localhost:8002
# 生产环境：https://demo.catwiki.ai
NEXT_PUBLIC_CLIENT_URL=http://localhost:8002

# 文档站点地址（帮助引导）
# 本地开发：http://localhost:8003
# Docker 开发：http://localhost:8003
# 生产环境：https://docs.catwiki.ai
NEXT_PUBLIC_DOCS_URL=http://localhost:8003
